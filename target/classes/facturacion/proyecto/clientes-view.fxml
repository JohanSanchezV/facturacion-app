<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="facturacion.proyecto.controller.ClientesController"
      spacing="18" alignment="TOP_CENTER" prefWidth="860" prefHeight="760">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Mantenimiento de Clientes"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="12" vgap="12" maxWidth="760">
        <Label text="Identificación:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtIdentificacion" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="txtNombre" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Apellido paterno:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtApellidoPaterno" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Apellido materno:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="txtApellidoMaterno" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Correo:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCorreo" prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Teléfono:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="txtTelefono" prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="ID Dirección:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtIdDireccion" prefWidth="260" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="12" alignment="CENTER">
        <Button text="Buscar" onAction="#buscarCliente" prefWidth="110"/>
        <Button text="Guardar nuevo" onAction="#insertarCliente" prefWidth="120"/>
        <Button text="Editar" onAction="#editarCliente" prefWidth="90"/>
        <Button text="Eliminar" onAction="#eliminarCliente" prefWidth="90"/>
        <Button text="Limpiar" onAction="#limpiarFormulario" prefWidth="90"/>
        <Button text="Volver" onAction="#volver" prefWidth="90"/>
    </HBox>

    <TableView fx:id="tblClientes" prefWidth="820" prefHeight="420">
        <columns>
            <TableColumn fx:id="colIdentificacion" text="Identificación" prefWidth="160"/>
            <TableColumn fx:id="colNombreCompleto" text="Nombre completo" prefWidth="280"/>
            <TableColumn fx:id="colCorreo" text="Correo" prefWidth="220"/>
            <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
