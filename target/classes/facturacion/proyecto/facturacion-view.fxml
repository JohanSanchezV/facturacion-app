<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="facturacion.proyecto.controller.FacturacionController"
      spacing="10" alignment="CENTER" prefWidth="550" prefHeight="500">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Facturación" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtIdFactura" promptText="ID Factura"/>
    <TextField fx:id="txtIdCliente" promptText="ID Cliente"/>
    <TextField fx:id="txtIdProducto" promptText="ID Producto"/>
    <TextField fx:id="txtCantidad" promptText="Cantidad"/>

    <Button text="Generar factura" onAction="#generarFactura" prefWidth="200"/>
    <Button text="Ver facturas emitidas" onAction="#abrirFacturasEmitidas" prefWidth="200"/>
    <Button text="Volver" onAction="#volver" prefWidth="200"/>

    <TableView fx:id="tblDetalleFactura" prefWidth="500" prefHeight="180">
        <columns>
            <TableColumn fx:id="colProductoFactura" text="Producto" prefWidth="220"/>
            <TableColumn fx:id="colCantidadFactura" text="Cantidad" prefWidth="100"/>
            <TableColumn fx:id="colTotalFactura" text="Total" prefWidth="150"/>
        </columns>
    </TableView>
</VBox>