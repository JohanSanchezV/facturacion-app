<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="facturacion.proyecto.controller.FacturasController"
      spacing="10" alignment="CENTER" prefWidth="600" prefHeight="420">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Facturas Emitidas" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Button text="Cargar facturas" onAction="#cargarFacturas" prefWidth="200"/>
    <Button text="Volver" onAction="#volver" prefWidth="200"/>

    <TableView fx:id="tblFacturas" prefWidth="550" prefHeight="250">
        <columns>
            <TableColumn fx:id="colIdFactura" text="ID Factura" prefWidth="100"/>
            <TableColumn fx:id="colFechaFactura" text="Fecha" prefWidth="150"/>
            <TableColumn fx:id="colClienteFactura" text="Cliente" prefWidth="200"/>
            <TableColumn fx:id="colMontoFactura" text="Monto" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>